{
  "name": "@rctf/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd ../../; bun --hot apps/api/src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.934.0",
    "@aws-sdk/client-ses": "^3.934.0",
    "@google-cloud/storage": "^7.17.3",
    "@hono/zod-validator": "^0.2.1",
    "@rctf/config": "workspace:*",
    "@rctf/db": "workspace:*",
    "@rctf/types": "workspace:*",
    "data-uri-to-buffer": "^6.0.2",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.4",
    "hono-pino": "^0.10.3",
    "ioredis": "^5.8.2",
    "mustache": "^4.2.0",
    "nodemailer": "^7.0.10",
    "pino": "^10.1.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mustache": "^4.2.6",
    "@types/nodemailer": "^7.0.3"
