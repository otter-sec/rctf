{
  "name": "@rctf/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd ../../; bun --watch apps/api/src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify --sourcemap=linked && bun build src/workers/leaderboard.ts --outdir dist --target bun --minify --sourcemap=linked && cp -r src/cache/scripts dist/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.994.0",
    "@aws-sdk/client-ses": "^3.994.0",
    "@fastify/proxy-addr": "^5.1.0",
    "@google-cloud/storage": "^7.19.0",
    "@hono/zod-validator": "^0.7.6",
    "@kubernetes/client-node": "^1.4.0",
    "@rctf/config": "workspace:*",
    "@rctf/db": "workspace:*",
    "@rctf/types": "workspace:*",
    "@rctf/util": "workspace:*",
    "data-uri-to-buffer": "^6.0.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.0",
    "hono-pino": "^0.10.3",
    "ioredis": "^5.9.3",
    "mustache": "^4.2.0",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/mustache": "^4.2.6",
    "@types/nodemailer": "^7.0.10"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
