{
  "name": "@rctf/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd ../../; bun --watch --no-orphans apps/api/src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify --sourcemap=linked && bun build src/workers/leaderboard.ts --outdir dist --target bun --minify --sourcemap=linked && cp -r src/cache/scripts dist/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1079.0",
    "@aws-sdk/client-ses": "3.1079.0",
    "@fastify/proxy-addr": "5.1.0",
    "@google-cloud/storage": "7.21.0",
    "@kubernetes/client-node": "1.4.0",
    "@rctf/config": "workspace:*",
    "@rctf/db": "workspace:*",
    "@rctf/scoring": "workspace:*",
    "@rctf/types": "workspace:*",
    "@rctf/util": "workspace:*",
    "data-uri-to-buffer": "8.0.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.28",
    "hono-pino": "0.10.3",
    "ioredis": "5.11.1",
    "mustache": "4.2.0",
    "nodemailer": "9.0.3",
    "openai": "6.45.0",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/mustache": "4.2.6",
    "@types/nodemailer": "8.0.1"
  },
  "peerDependencies": {
    "typescript": "7.0.2"
  }
}
