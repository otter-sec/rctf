{
  "name": "@rctf/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "prepare": "bunx --bun svelte-kit sync || echo ''",
    "check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check"
  },
  "dependencies": {
    "@rctf/types": "workspace:*",
    "@rctf/util": "workspace:*",
    "@tanstack/svelte-query": "^6.0.18",
    "@tanstack/svelte-virtual": "^3.13.18",
    "@types/d3-array": "^3.2.2",
    "@xstate/svelte": "^5.0.0",
    "d3-array": "^3.2.4",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "modern-screenshot": "^4.6.8",
    "xstate": "^5.28.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@internationalized/date": "^3.11.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.52.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/dompurify": "^3.2.0",
    "bits-ui": "^2.16.1",
    "clsx": "^2.1.1",
    "layerchart": "2.0.0-next.46",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.0",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.0"
  }
}
