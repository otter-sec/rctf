{
  "name": "@rctf/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun --no-orphans vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "prepare": "bunx --bun svelte-kit sync || echo ''",
    "check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check",
    "test": "bun test tests"
  },
  "dependencies": {
    "@rctf/types": "workspace:*",
    "@rctf/util": "workspace:*",
    "@shikijs/langs": "4.3.1",
    "@shikijs/themes": "4.3.1",
    "@tanstack/svelte-query": "6.1.36",
    "@tanstack/virtual-core": "3.17.3",
    "@zag-js/accordion": "1.42.0",
    "@zag-js/avatar": "1.42.0",
    "@zag-js/combobox": "1.42.0",
    "@zag-js/dialog": "1.42.0",
    "@zag-js/menu": "1.42.0",
    "@zag-js/progress": "1.42.0",
    "@zag-js/splitter": "1.42.0",
    "@zag-js/svelte": "1.42.0",
    "@zag-js/tabs": "1.42.0",
    "@zag-js/toast": "1.42.0",
    "@zag-js/tooltip": "1.42.0",
    "@zag-js/tree-view": "1.42.0",
    "dompurify": "3.4.11",
    "marked": "18.0.5",
    "modern-screenshot": "4.7.0",
    "shiki": "4.3.1",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.69.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/bun": "1.3.14",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "typescript": "5.9.3",
    "vite": "8.1.3"
  }
}
