{
  "name": "@rctf/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "prepare": "bunx --bun svelte-kit sync || echo ''",
    "check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check"
  },
  "dependencies": {
    "@iconify/svelte": "^5.1.0",
    "@rctf/util": "workspace:*",
    "@rctf/types": "workspace:*",
    "@tanstack/svelte-query": "^5.62.16",
    "@tanstack/svelte-virtual": "^3.13.13",
    "@types/d3-array": "^3.2.2",
    "@xstate/svelte": "^5.0.0",
    "d3-array": "^3.2.4",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.0",
    "marked": "^17.0.1",
    "modern-screenshot": "^4.6.7",
    "xstate": "^5.24.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@iconify-svelte/tabler": "^1.0.0",
    "@internationalized/date": "^3.8.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.47.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/dompurify": "^3.2.0",
    "bits-ui": "^2.11.0",
    "clsx": "^2.1.1",
    "layerchart": "2.0.0-next.27",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.41.0",
    "svelte-check": "^4.3.3",
    "svelte-sonner": "^1.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^7.1.10"
  }
}
