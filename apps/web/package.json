{
  "name": "@rctf/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun --no-orphans vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "prepare": "bunx --bun svelte-kit sync || echo ''",
    "check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check"
  },
  "dependencies": {
    "@rctf/types": "workspace:*",
    "@rctf/util": "workspace:*",
    "@tanstack/svelte-query": "6.1.0",
    "@tanstack/svelte-virtual": "3.13.22",
    "@types/d3-array": "3.2.2",
    "@xstate/svelte": "5.0.0",
    "d3-array": "3.2.4",
    "date-fns": "4.1.0",
    "dompurify": "3.4.3",
    "marked": "17.0.4",
    "modern-screenshot": "4.6.8",
    "xstate": "5.28.0",
    "yaml": "2.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@internationalized/date": "3.12.0",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.60.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.2.1",
    "bits-ui": "2.16.3",
    "clsx": "2.1.1",
    "layerchart": "2.0.0-next.62",
    "mode-watcher": "1.1.0",
    "paneforge": "1.0.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "svelte": "5.55.7",
    "svelte-check": "4.4.5",
    "svelte-sonner": "1.1.0",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "8.0.10"
  }
}
