    "astro": "6.4.4",
    "github-slugger": "2.0.0",
    "hast-util-select": "6.0.4",
    "hast-util-to-html": "9.0.5",
    "hastscript": "9.0.1",
    "satori": "0.26.0",
    "satteri": "0.8.0",
    "satteri-expressive-code": "0.1.10",
