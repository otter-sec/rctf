---
import { ScrollArea } from '@/components/ui/scroll-area'
import { renderDescription } from '@/lib/render-description'
import { renderTocHeading } from '@/lib/toc-heading'
import { cn, getHeadingMargin } from '@/lib/utils'
import type { MarkdownHeading } from 'astro'

interface Props {
  headings: MarkdownHeading[]
  minDepth?: number
  maxDepth?: number
  title: string
  titleTargetId: string
}

const { headings, minDepth = 2, maxDepth = 4, title, titleTargetId } = Astro.props
const renderedTitle = await renderDescription(title)
const visible = headings.filter(h => h.depth >= minDepth && h.depth <= maxDepth)
---

{
  visible.length > 0 && (
    <aside
      data-pagefind-ignore
      data-toc-sidebar-root
      class='sticky top-16 hidden h-[calc(100vh-8rem)] max-w-xs flex-col self-start xl:flex'
    >
      <div
        data-toc-sidebar-title-wrapper
        data-toc-title-target={titleTargetId}
        data-open='false'
        class='grid shrink-0 grid-rows-[0fr] px-4 transition-[grid-template-rows] duration-200 ease-out data-[open=true]:grid-rows-[1fr]'
      >
        <div class='overflow-hidden'>
          <span
            class='text-foreground block pb-3 text-base font-medium text-balance'
            data-doc-title
            set:html={renderedTitle.html}
          />
        </div>
      </div>
      <ScrollArea
        client:load
        className='min-h-0 flex-1 overflow-y-auto'
        type='hover'
        data-toc-scroll-area
      >
        <ul class='flex list-none flex-col gap-y-1.5 px-4'>
          {visible.map(heading => (
            <li
              data-toc-item={heading.slug}
              class={cn('text-foreground/60 text-sm', getHeadingMargin(heading.depth))}
            >
              <a
                href={`#${heading.slug}`}
                data-heading-link={heading.slug}
                class='hover:text-foreground block underline decoration-transparent underline-offset-[3px] transition-colors duration-200 hover:decoration-inherit'
              >
                <span data-toc-text set:html={renderTocHeading(heading.text)} />
              </a>
            </li>
          ))}
        </ul>
      </ScrollArea>
    </aside>
  )
}

<script>
  import { mountTocSidebar } from '@/lib/client/toc-sidebar'

  mountTocSidebar()
</script>
