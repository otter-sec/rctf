---
import {
  getScoreProviderEntries,
  type ScoreContext,
  type ScoreProvider,
  type ScoreProviderName,
} from '@rctf/scoring'

type ScoreProviderSlug = ScoreProviderName extends `scores/${infer Slug}` ? Slug : never
type ScoreProviderFocus = ScoreProviderName | ScoreProviderSlug

interface Props {
  type?: 'solves' | 'time'
  focus?: ScoreProviderFocus
}

type Series = {
  label: ScoreProviderName
  name: ScoreProviderName
  color: string
  values: number[]
}

const { type = 'solves', focus } = Astro.props

const width = 720
const height = 360
const plot = { left: 58, top: 28, right: 24, bottom: 56 }
const plotWidth = width - plot.left - plot.right
const plotHeight = height - plot.top - plot.bottom
const minPoints = 100
const maxPoints = 500
const maxSolves = 50

const chartColors = [
  '#C10007',
  '#2563EB',
  '#D97706',
  '#7C3AED',
  '#059669',
  '#0891B2',
] as const
const colorForProvider = (index: number) =>
  chartColors[index % chartColors.length] ?? chartColors[0]

const samples =
  type === 'solves'
    ? Array.from({ length: maxSolves + 1 }, (_, i) => i)
    : Array.from({ length: 101 }, (_, i) => i)

const xMax = samples.at(-1) ?? 1
const yMin = type === 'solves' ? 0 : minPoints
const yMax = maxPoints

const providerEntries = getScoreProviderEntries().map((entry, index) => ({
  ...entry,
  provider: entry.create({}),
  color: colorForProvider(index),
}))
const isTimeBasedProvider = (provider: ScoreProvider) =>
  provider.requiredFields.includes('firstSolveTime')
const chartProviderEntries = providerEntries.filter(({ provider }) =>
  type === 'time' ? isTimeBasedProvider(provider) : !isTimeBasedProvider(provider),
)

const baseContext = {
  minPoints,
  maxPoints,
  maxSolves,
  eventStartTime: 0,
  eventEndTime: 100,
} satisfies Pick<
  ScoreContext,
  'minPoints' | 'maxPoints' | 'maxSolves' | 'eventStartTime' | 'eventEndTime'
>
const contextForSample = (sample: number): ScoreContext => ({
  ...baseContext,
  solves: type === 'solves' ? sample : 0,
  firstSolveTime: type === 'time' ? sample : null,
})
const resolveFocusName = (value: ScoreProviderFocus | undefined): ScoreProviderName | null => {
  if (!value) return null
  const name = value.startsWith('scores/') ? value : `scores/${value}`
  return providerEntries.some((entry) => entry.name === name) ? (name as ScoreProviderName) : null
}
const focusedName = resolveFocusName(focus)
const series: Series[] = chartProviderEntries.map(({ name, color, provider }) => ({
  label: name,
  name,
  color,
  values: samples.map((sample) => provider.calculate(contextForSample(sample))),
}))

const x = (value: number) => plot.left + (value / xMax) * plotWidth
const y = (value: number) =>
  plot.top + (1 - (value - yMin) / (yMax - yMin)) * plotHeight

const polylines = series
  .map((item) => ({
    ...item,
    focused: type === 'time' || item.name === focusedName,
    points: samples
      .map(
        (sample, i) =>
          `${x(sample).toFixed(2)},${y(item.values[i] ?? yMin).toFixed(2)}`,
      )
      .join(' '),
  }))
  .sort((a, b) => Number(a.focused) - Number(b.focused))

const xTicks =
  type === 'solves' ? [0, 10, 20, 30, 40, 50] : [0, 20, 40, 60, 80, 100]
const yTicks =
  type === 'solves' ? [0, 100, 200, 300, 400, 500] : [100, 200, 300, 400, 500]
const focusedLabel = series.find((item) => item.name === focusedName)?.label
const primaryLabel = focusedLabel ?? series[0]?.label
const title =
  type === 'solves'
    ? `${focusedLabel ?? 'Solve-based'} score decay`
    : `${primaryLabel ?? 'Time-based'} first-solve scoring`
const description =
  type === 'solves'
    ? `${focusedLabel ?? 'Solve-based providers'} shown against the other solve-based scoring curves as challenge solves increase from 0 to 50.`
    : 'Time-based providers score a challenge from when its first solve occurs during the event.'
const chartId = `score-chart-${type}-${(focusedName ?? series[0]?.name ?? 'providers').replace('/', '-')}`
---

<figure class="not-prose my-6 overflow-hidden rounded-lg border">
  <svg
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-labelledby={`${chartId}-title ${chartId}-desc`}
    class="bg-background block w-full"
  >
    <title id={`${chartId}-title`}>{title}</title>
    <desc id={`${chartId}-desc`}>{description}</desc>

    <rect x="0" y="0" width={width} height={height} class="fill-background" />

    {
      yTicks.map((tick) => (
        <>
          <line
            x1={plot.left}
            x2={width - plot.right}
            y1={y(tick)}
            y2={y(tick)}
            class="stroke-border"
            stroke-width="1"
          />
          <text
            x={plot.left - 12}
            y={y(tick) + 4}
            text-anchor="end"
            class="fill-muted-foreground text-[11px]"
          >
            {tick}
          </text>
        </>
      ))
    }

    {
      xTicks.map((tick) => (
        <>
          <line
            x1={x(tick)}
            x2={x(tick)}
            y1={plot.top}
            y2={height - plot.bottom}
            class="stroke-border/50"
            stroke-width="1"
          />
          <text
            x={x(tick)}
            y={height - plot.bottom + 22}
            text-anchor="middle"
            class="fill-muted-foreground text-[11px]"
          >
            {tick}
          </text>
        </>
      ))
    }

    <line
      x1={plot.left}
      x2={plot.left}
      y1={plot.top}
      y2={height - plot.bottom}
      class="stroke-foreground"
      stroke-width="1.5"
    />
    <line
      x1={plot.left}
      x2={width - plot.right}
      y1={height - plot.bottom}
      y2={height - plot.bottom}
      class="stroke-foreground"
      stroke-width="1.5"
    />

    {
      polylines.map((item) => (
        <polyline
          points={item.points}
          fill="none"
          stroke={item.color}
          stroke-width={item.focused ? '4' : '2'}
          stroke-linecap="round"
          stroke-linejoin="round"
          opacity={item.focused ? '1' : '0.18'}
          vector-effect="non-scaling-stroke"
        />
      ))
    }

    <text
      x={plot.left + plotWidth / 2}
      y={height - 14}
      text-anchor="middle"
      class="fill-muted-foreground text-[12px]"
    >
      {type === 'solves' ? 'Solves' : 'Event elapsed before first solve (%)'}
    </text>
    <text
      x="18"
      y={plot.top + plotHeight / 2}
      text-anchor="middle"
      transform={`rotate(-90 18 ${plot.top + plotHeight / 2})`}
      class="fill-muted-foreground text-[12px]"
    >
      Points
    </text>
  </svg>
  <figcaption
    class="border-border/70 flex flex-wrap gap-x-4 gap-y-2 border-t px-4 py-3 text-xs"
  >
    {
      series.map((item) => (
        <span
          class:list={[
            'inline-flex items-center gap-2',
            type === 'time' || item.name === focusedName
              ? 'text-foreground font-medium'
              : 'text-muted-foreground opacity-60',
          ]}
        >
          <span
            class="inline-block h-2.5 w-2.5 rounded-full"
            style={`background-color: ${item.color}`}
          />
          <span>{item.label}</span>
        </span>
      ))
    }
  </figcaption>
</figure>
