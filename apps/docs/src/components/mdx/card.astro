---
import Link from '@/components/link.astro'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  icon?: string
  href?: string
  class?: string
}

const { title, icon, href, class: className } = Astro.props

const baseClass = cn(
  'not-prose flex flex-col gap-2 rounded-lg border p-5',
  className,
)
const linkClass = cn(
  'group hover:border-foreground/30 transition-colors no-underline',
  baseClass,
)
---

{
  href ? (
    <Link href={href} class={linkClass}>
      {icon && (
        <Icon
          name={icon}
          class="text-muted-foreground group-hover:text-foreground size-5 transition-colors"
        />
      )}
      <h3 class="text-foreground text-base font-medium leading-tight m-0">
        {title}
      </h3>
      <p class="text-muted-foreground text-sm leading-relaxed m-0">
        <slot />
      </p>
      <span class="text-muted-foreground group-hover:text-foreground mt-2 inline-flex items-center gap-1 text-xs transition-colors">
        Learn more
        <Icon
          name="lucide:arrow-right"
          class="size-3 transition-transform group-hover:translate-x-0.5"
        />
      </span>
    </Link>
  ) : (
    <div class={baseClass}>
      {icon && <Icon name={icon} class="text-muted-foreground size-5" />}
      <h3 class="text-foreground text-base font-medium leading-tight m-0">
        {title}
      </h3>
      <p class="text-muted-foreground text-sm leading-relaxed m-0">
        <slot />
      </p>
    </div>
  )
}
