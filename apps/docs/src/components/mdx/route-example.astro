---
import CurlExample from '@/components/mdx/curl-example.astro'
import ResponseTabs from '@/components/mdx/response-tabs.astro'

interface ResponseDef {
  kind: string
  status: number
  message: string
  dataSchema?: unknown
}

interface Props {
  def: any
  baseUrl?: string
  pick?: string[]
  body?: Record<string, unknown>
  query?: Record<string, unknown>
  params?: Record<string, unknown>
  extra?: ResponseDef[]
  examples?: Record<string, unknown>
}

const {
  def,
  baseUrl = 'https://rctf-new-dev.es3n1n.io',
  pick,
  body,
  query,
  params,
  extra = [],
  examples = {},
} = Astro.props
---

<CurlExample def={def} baseUrl={baseUrl} pick={pick} body={body} query={query} params={params} />
<ResponseTabs def={def} extra={extra} examples={examples} />
