---
import { cn } from '@/lib/utils'
import { cva, type VariantProps } from 'class-variance-authority'

const badgeVariants = cva(
  'inline-flex items-center gap-1 rounded-md border px-1.5 py-px font-mono text-[0.65rem] font-medium uppercase tracking-wide leading-4',
  {
    variants: {
      variant: {
        default: 'border-border bg-muted/50 text-foreground',
        note: 'border-blue-500/30 bg-blue-500/10 text-blue-700 dark:text-blue-300',
        tip: 'border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-300',
        caution:
          'border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-300',
        danger: 'border-red-500/30 bg-red-500/10 text-red-700 dark:text-red-300',
      },
    },
    defaultVariants: {
      variant: 'default',
    },
  },
)

type Variant = NonNullable<VariantProps<typeof badgeVariants>['variant']>

interface Props {
  variant?: Variant
  class?: string
}

const { variant = 'default', class: className } = Astro.props
---

<span class={cn(badgeVariants({ variant }), className)}>
  <slot />
</span>
