---
import { renderDescription } from '@/lib/render-description'
import { walkObjectSchema } from '@/lib/route-introspect'

interface Props {
  def: any
  source?: 'body' | 'query' | 'params'
}

const { def, source = 'body' } = Astro.props

const rows = await Promise.all(
  walkObjectSchema(def?.[source]).map(async field => ({
    name: field.name,
    typeHtml: (await renderDescription(`\`${field.typeLabel}{:ts}\``)).html,
    required: field.required ? 'Yes' : 'No',
    notesHtml: field.description ? (await renderDescription(field.description)).html : '',
  }))
)
---

{
  rows.length > 0 && (
    <table>
      <thead>
        <tr>
          <th>Field</th>
          <th>Type</th>
          <th>Required</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {rows.map(row => (
          <tr>
            <td>
              <code>{row.name}</code>
            </td>
            <td>
              <Fragment set:html={row.typeHtml} />
            </td>
            <td>{row.required}</td>
            <td>
              <Fragment set:html={row.notesHtml} />
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )
}
