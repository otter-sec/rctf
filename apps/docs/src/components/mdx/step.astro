---
interface Props {
  title?: string
}

const { title } = Astro.props
---

<div class="step grid grid-cols-[2rem_1fr] gap-x-4">
  <div class="flex flex-col items-center">
    <div class="step-num bg-muted text-muted-foreground flex size-8 shrink-0 items-center justify-center rounded-full text-sm font-medium tabular-nums" />
    <div class="step-connector bg-border mt-1 w-px grow" />
  </div>
  <div class="step-content pb-8 pt-1">
    {title && (
      <span class="text-foreground mb-3 block text-lg leading-tight">{title}</span>
    )}
    <div class="prose max-w-none [&>*:first-child]:mt-0 [&>*:last-child]:mb-0">
      <slot />
    </div>
  </div>
</div>

<style>
  .step {
    counter-increment: step;
  }

  .step-num::before {
    content: counter(step);
  }

  .step:last-child .step-connector {
    display: none;
  }

  .step:last-child .step-content {
    padding-bottom: 0;
  }
</style>
