<script is:inline>
  ;(() => {
    const type = performance.getEntriesByType('navigation')[0]?.type
    if (type && type !== 'navigate') return
    if (location.hash) return
    let pathname = location.pathname.replace(/\/+$/, '')
    try {
      pathname = decodeURIComponent(pathname)
    } catch {}
    document
      .querySelector(`article[data-embedded][data-url="${pathname}"]`)
      ?.scrollIntoView({ behavior: 'instant' })
  })()
</script>

<script>
  import { hashId, normalizePath } from '@/lib/utils'

  const articles = [...document.querySelectorAll<HTMLElement>('article[data-url]')]

  const list = document.querySelector('page-nav nav > ul > li > ul')
  const parentLink = list?.querySelector('a')
  let crumb = list?.querySelector<HTMLElement>('li[data-depth="1"]')
  if (list && !crumb) {
    crumb = document.createElement('li')
    crumb.dataset.depth = '1'
    crumb.hidden = true
    crumb.append(document.createElement('a'))
    list.append(crumb)
  }
  const crumbLink = crumb?.querySelector('a')

  const hashTarget = (hash: string) => {
    try {
      return document.getElementById(hashId(hash))
    } catch {
      return null
    }
  }

  const localTarget = (link: HTMLAnchorElement) => {
    if (link.getAttribute('href')?.startsWith('#')) return hashTarget(link.hash)
    if (link.origin !== location.origin || link.search) return null
    const article = articles.find(article => article.dataset.url === normalizePath(link.pathname))
    if (!article) return null
    return link.hash ? (hashTarget(link.hash) ?? article) : article
  }

  const syncCrumb = (article: HTMLElement) => {
    if (!crumb || !crumbLink || !parentLink) return
    if (article === articles[0]) {
      crumb.hidden = true
      crumbLink.removeAttribute('aria-current')
      parentLink.setAttribute('aria-current', 'page')
    } else {
      crumb.hidden = false
      crumbLink.href = article.dataset.url ?? ''
      crumbLink.textContent = article.querySelector('header h1')?.textContent ?? ''
      crumbLink.setAttribute('aria-current', 'page')
      parentLink.removeAttribute('aria-current')
    }
  }

  const treeLinks = [...document.querySelectorAll<HTMLAnchorElement>('sidebar-tree a[href]')].map(
    link => [normalizePath(link.pathname), link] as const
  )

  const syncTree = (url: string) => {
    for (const [href, link] of treeLinks) {
      if (href === url) link.setAttribute('aria-current', 'page')
      else link.removeAttribute('aria-current')
    }
  }

  const sync = (article: HTMLElement, hash = '') => {
    const { url, title } = article.dataset
    if (!url) return
    history.replaceState(history.state, '', url + hash)
    if (title) document.title = title
    syncCrumb(article)
    if (treeLinks.length > 0) syncTree(url)
  }

  document.addEventListener('click', event => {
    if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey)
      return
    const link = (event.target as Element).closest?.('a[href]')
    if (!(link instanceof HTMLAnchorElement) || link.target || link.hasAttribute('download')) return
    const target = localTarget(link)
    const article = target?.closest<HTMLElement>('article[data-url]')
    if (!target || !article) return
    event.preventDefault()
    if (target === articles[0]) {
      scrollTo({ top: 0 })
    } else {
      target.scrollIntoView()
    }
    sync(article, target === article ? '' : link.hash)
  })

  const atBottom = () => {
    const max = document.documentElement.scrollHeight - innerHeight
    return max > 0 && scrollY >= max - 2
  }

  const currentArticle = () => {
    if (atBottom()) return articles[articles.length - 1]
    const band = innerHeight * 0.2
    return articles.find(article => {
      const rect = article.getBoundingClientRect()
      return rect.top <= band && rect.bottom > band
    })
  }

  const update = () => {
    const current = currentArticle()
    if (!current || current.dataset.url === normalizePath(location.pathname)) {
      return
    }
    const hash =
      location.hash && hashTarget(location.hash)?.closest('article[data-url]') === current
        ? location.hash
        : ''
    sync(current, hash)
  }

  addEventListener('scroll', update, { passive: true })
  update()
</script>
