---
import SearchTrigger from '@/components/docs/search-trigger.astro'
import EditLink from '@/components/docs/edit-link.astro'
import Sidebar from '@/components/docs/sidebar.astro'
import Link from '@/components/link.astro'
import ThemeToggle from '@/components/theme-toggle.astro'
import { SITE, SOCIAL_LINKS } from '@/consts'
import { BASE_URL } from '@/lib/docs'
import type { SidebarNode } from '@/types'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import wordmarkDark from '@/assets/wordmark-dark.svg'
import wordmarkLight from '@/assets/wordmark-light.svg'

interface Props {
  tree: SidebarNode[]
  editUrl?: string | null
}

const { tree, editUrl } = Astro.props
const gitHubLink = SOCIAL_LINKS.find((link) => link.label === 'GitHub')
---

<aside
  class="hidden xl:block"
  aria-label="Site navigation"
  transition:persist="docs-aside"
>
  <div
    class="sticky top-[var(--docs-announcement-offset,0px)] flex h-[calc(100dvh-var(--docs-announcement-offset,0px))] flex-col gap-4 pt-16 pr-4 pb-6 pl-6"
  >
    <Link
      href={BASE_URL}
      class="flex items-center no-underline"
      aria-label={SITE.title}
    >
      <Image
        src={wordmarkLight}
        alt={SITE.title}
        class="block h-6 w-auto dark:hidden"
      />
      <Image
        src={wordmarkDark}
        alt={SITE.title}
        class="hidden h-6 w-auto dark:block"
      />
    </Link>

    <SearchTrigger />

    <nav class="-mx-2 min-h-0 flex-1" aria-label="Documentation" data-sidebar-nav>
      <Sidebar tree={tree} class="h-full px-2" />
    </nav>

    <div class="border-border/70 flex h-12 items-center justify-between border-t">
      <ThemeToggle transition:persist />
      <div class="flex items-center gap-1">
        {
          gitHubLink && (
            <Link
              href={gitHubLink.href}
              external
              class="text-muted-foreground hover:bg-muted/50 hover:text-foreground inline-flex size-8 items-center justify-center rounded-md no-underline transition-colors"
              aria-label="GitHub"
            >
              <Icon name="lucide:github" class="size-4" />
            </Link>
          )
        }
        <EditLink id="docs-edit-link" href={editUrl ?? '#'} variant="icon" hidden={!editUrl} />
      </div>
    </div>
  </div>
</aside>

<script>
  import { mountDocsAside } from '@/lib/client/docs-aside'

  mountDocsAside()
</script>
