---
import { Icon } from 'astro-icon/components'
import Link from '@/components/link.astro'
import { cn } from '@/lib/utils'

interface Props {
  href: string
  variant?: 'text' | 'icon'
  class?: string
  [key: string]: unknown
}

const { href, variant = 'text', class: className, ...rest } = Astro.props
const isIcon = variant === 'icon'
---

<Link
  href={href}
  class={cn(
    isIcon
      ? 'text-muted-foreground hover:bg-muted/50 hover:text-foreground inline-flex size-8 items-center justify-center rounded-md no-underline transition-colors'
      : 'text-muted-foreground hover:text-foreground inline-flex items-center gap-1.5 text-sm underline decoration-transparent underline-offset-[3px] transition-colors hover:decoration-inherit',
    className,
  )}
  external
  aria-label={isIcon ? 'Edit this page' : undefined}
  title={isIcon ? 'Edit this page' : undefined}
  {...rest}
>
  <Icon name="lucide:pencil" class={isIcon ? 'size-4' : 'size-3.5'} />
  {!isIcon && 'Edit this page'}
</Link>
