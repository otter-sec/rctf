---
import '@/styles/reset.css'
import '@/styles/fonts.css'
import '@/styles/color.css'
import '@/styles/typography.css'
import '@/styles/typography-headings.css'
import '@/styles/typography-inline.css'
import '@/styles/typography-lists.css'
import '@/styles/typography-block.css'
import '@/styles/typography-tables.css'
import '@/styles/callout.css'
import '@/styles/steps.css'
import '@/styles/cards.css'
import '@/styles/file-tree.css'
import '@/styles/tabs.css'
import '@/styles/layout.css'
import '@/styles/reference.css'
import '@/styles/scroll-fade.css'
import '@/styles/icon-button.css'
import '@/styles/bar.css'
import '@/styles/shape.css'
import CopyCommands from '@/components/CopyCommands.astro'
import Footer from '@/components/Footer.astro'
import MetaHead from '@/components/MetaHead.astro'
import Search from '@/components/Search.astro'
import Sidebar from '@/components/Sidebar.astro'
import TabGroups from '@/components/TabGroups.astro'
import { SITE } from '@/consts'
import type { InlineLabel } from '@/lib/content'
import type { DocsTreeNode } from '@/lib/docs'

type Props = {
  crumbs?: { label: InlineLabel; href: string }[]
  tree?: DocsTreeNode[]
  wide?: boolean
}

const { crumbs, tree, wide } = Astro.props
---

<html lang={SITE.locale} dir={SITE.dir}>
  <MetaHead>
    <slot name="head" />
  </MetaHead>
  <body>
    <page-grid>
      <page-header>
        <page-nav>
          <Sidebar crumbs={crumbs} tree={tree}><slot name="actions" slot="actions" /></Sidebar>
        </page-nav>
        {
          Astro.slots.has('toc') && !wide && (
            <page-toc>
              <slot name="toc" />
            </page-toc>
          )
        }
      </page-header>
      <page-content data-wide={wide || undefined}>
        <main><slot /></main>
        <page-footer><Footer /></page-footer>
      </page-content>
    </page-grid>
    <CopyCommands />
    <TabGroups />
    <Search />
  </body>
</html>

<style>
  page-grid {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
    gap: var(--grid-gutter);
    max-width: var(--grid-max-width);
    min-height: 100svh;
    margin-inline: auto;
    padding-inline: var(--grid-gutter);
    padding-block-start: var(--page-offset-top);

    /* Tablet: nav sidebar stays, TOC moves atop the content column. */
    @media (width >= 48rem) and (width < 64rem) {
      grid-template-columns:
        max(calc(2 * var(--grid-column-width) + var(--grid-gutter)), 9rem)
        minmax(0, 1fr);
      grid-template-rows: auto 1fr;
      grid-template-areas: 'nav toc' 'nav content';

      &:not(:has(page-toc)) {
        grid-template-areas: 'nav content' 'nav content';
      }
    }

    @media (width < 48rem) {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      padding-block-start: 0;
    }
  }

  page-header {
    display: contents;

    @media (width < 48rem) {
      display: block;
      grid-column: 1 / -1;
      position: sticky;
      top: 0;
      z-index: 10;
      min-width: 0;
      margin-inline: calc(-1 * var(--grid-gutter));
    }
  }

  page-nav {
    display: block;
    min-width: 0;
    grid-column: 1 / 3;
    grid-row: 1;

    /* Fixed like desktop so the page's overscroll never moves it; the grid keeps
       the nav column reserved, so pulling it out of flow shifts nothing. */
    @media (width >= 48rem) and (width < 64rem) {
      grid-area: nav;
      position: fixed;
      inset-block: var(--page-offset-top) var(--page-offset-bottom);
      inset-inline-start: var(--grid-edge);
      width: max(calc(2 * var(--grid-column-width) + var(--grid-gutter)), 9rem);
    }

    @media screen and (width >= 64rem) {
      position: fixed;
      inset-block: var(--page-offset-top) var(--page-offset-bottom);
      inset-inline-start: var(--grid-edge);
      width: calc(2 * var(--grid-column-width) + var(--grid-gutter));
    }
  }

  page-toc {
    display: block;
    min-width: 0;
    grid-column: 10 / 13;
    grid-row: 1;

    @media (width >= 48rem) and (width < 64rem) {
      grid-area: toc;
      position: sticky;
      top: 0;
      z-index: 10;

      /* The bar sits inside the content column here, not edge-to-edge, so drop
         the mobile full-bleed gutter and inset border so it aligns with prose. */
      :global([data-bar]) {
        padding-inline: 0;
        border-image: none;
      }
    }

    @media screen and (width >= 64rem) {
      position: fixed;
      inset-block: var(--page-offset-top) var(--page-offset-bottom);
      inset-inline-end: var(--grid-edge);
      width: calc(3 * var(--grid-column-width) + 2 * var(--grid-gutter));
    }
  }

  page-content {
    display: flex;
    flex-direction: column;
    grid-column: 3 / 10;
    grid-row: 1;
    min-width: 0;
    margin-block-start: -0.1em;

    main {
      flex: 1;
    }

    page-footer {
      display: block;
      margin-block-start: var(--space-xl);
    }

    @media (width >= 48rem) and (width < 64rem) {
      grid-area: content;
    }

    @media (width < 48rem) {
      grid-column: 1 / -1;
      grid-row: auto;
      inline-size: 100%;
      max-inline-size: var(--measure);
      margin-inline: auto;
    }
  }

  @media (width >= 64rem) {
    page-content[data-wide] {
      grid-column: 3 / 13;
    }
  }
</style>
