---
import DocsAside from '@/components/docs/docs-aside.astro'
import MobileSidebar from '@/components/docs/mobile-sidebar.astro'
import Header from '@/components/header.astro'
import PageHead from '@/components/page-head.astro'
import Hero from '@/components/splash/hero.astro'
import TOCHeader from '@/components/toc-header.astro'
import TOCSidebar from '@/components/toc-sidebar.astro'
import { SITE } from '@/consts'
import Base from '@/layouts/base.astro'
import type { Doc } from '@/lib/docs'
import { cn } from '@/lib/utils'
import type { MarkdownHeading } from 'astro'
import type { FlatDoc, SidebarNode } from '@/types'

interface Props {
  doc: Doc
  headings: MarkdownHeading[]
  sidebar: SidebarNode[]
  prev: FlatDoc | null
  next: FlatDoc | null
  editUrl: string | null
  lastUpdated: Date | null
  tocMinDepth: number
  tocMaxDepth: number
  tocEnabled: boolean
  breadcrumbs: { label: string; href?: string; icon?: string }[]
}

const {
  doc,
  headings,
  sidebar,
  prev,
  next,
  editUrl,
  lastUpdated,
  tocMinDepth,
  tocMaxDepth,
  tocEnabled,
  breadcrumbs,
} = Astro.props

const isSplash = doc.data.template === 'splash'
const showToc = tocEnabled && !isSplash

const offsetClass = 'xl:ml-[max(0px,calc((100vw-16rem-96rem)/2))]'
---

<Base>
  <PageHead
    slot="head"
    title={doc.data.title}
    description={doc.data.description}
  />
  {editUrl && <meta slot="head" name="docs-edit-url" content={editUrl} />}

  <div class="grid flex-1 grid-cols-1 xl:grid-cols-[16rem_minmax(0,1fr)]">
    <DocsAside tree={sidebar} />
    <MobileSidebar tree={sidebar} />

    <div class="flex flex-col overflow-x-clip xl:pt-16 xl:pb-6">
      <header
        class="bg-background/80 sticky top-0 z-40 border-b backdrop-blur-sm xl:hidden"
      >
        <Header />
      </header>

      {showToc && <TOCHeader headings={headings} minDepth={tocMinDepth} maxDepth={tocMaxDepth} />}

      <main
        class={cn(
          'mx-auto flex w-full grow flex-col gap-y-6 px-4',
          offsetClass,
        )}
      >
        <div
          class="grid grid-cols-1 gap-8 xl:grid-cols-[minmax(0,42rem)_minmax(14rem,16rem)]"
        >
          <article
            class="mx-auto w-full min-w-0 max-w-2xl xl:mx-0"
            data-pagefind-body
          >
            {
              isSplash ? (
                doc.data.hero && <Hero hero={doc.data.hero} />
              ) : (
                <header class="mt-6 mb-8 flex flex-col gap-3 xl:-mt-3">
                  <h1
                    id="post-title"
                    class="text-3xl leading-tight font-medium sm:text-4xl"
                  >
                    {doc.data.title}
                  </h1>
                  {doc.data.description && (
                    <p class="text-muted-foreground text-lg text-pretty">
                      {doc.data.description}
                    </p>
                  )}
                </header>
              )
            }

            <div class="prose max-w-none">
              <slot />
            </div>

            <footer
              class="text-muted-foreground border-border/70 mt-16 flex h-12 items-center border-t text-sm"
              data-pagefind-ignore
            >
              &copy; {new Date().getFullYear()} {SITE.title}
            </footer>
          </article>

          {
            showToc ? (
              <TOCSidebar
                headings={headings}
                minDepth={tocMinDepth}
                maxDepth={tocMaxDepth}
                title={doc.data.title}
              />
            ) : (
              <div class="hidden xl:block" aria-hidden="true" />
            )
          }
        </div>
      </main>
    </div>
  </div>
</Base>

<script>
  const ensureKatexStyles = () => {
    if (!document.querySelector('.katex')) return
    if (document.querySelector('link[href*="katex.min.css"]')) return

    const link = document.createElement('link')
    link.rel = 'stylesheet'
    link.href =
      'https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css'
    document.head.appendChild(link)
  }

  document.addEventListener('astro:page-load', ensureKatexStyles)
  document.addEventListener('astro:after-swap', ensureKatexStyles)
</script>
