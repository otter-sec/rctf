{
  "name": "rctf",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "apps/admin-bot",
    "apps/api",
    "apps/cli",
    "apps/docs",
    "apps/web",
    "apps/web-new",
    "packages/*",
    "tests/server",
    "tests/admin-bot",
    "tests/admin-bot-e2e"
  ],
  "overrides": {
    "yaml": "2.9.0"
  },
  "scripts": {
    "dev": "bun --ellide-lines=0 run --filter '@rctf/api' --filter '@rctf/web' dev",
    "dev:api": "bun run --filter '@rctf/api' dev",
    "dev:web": "bun run --filter '@rctf/web' dev",
    "dev:docs": "bun run --filter '@rctf/docs' dev",
    "dev:seed": "bun run apps/cli/src/index.ts seed",
    "dev:mock": "bun run db:migrate && bun run dev:seed && bun run dev",
    "build": "bun run --filter '*' build",
    "build:api": "bun run --filter '@rctf/api' build",
    "build:web": "bun run --filter '@rctf/web' build",
    "test": "bun run test:server && bun run test:admin-bot && bun run test:admin-bot:e2e",
    "test:server": "cd tests/server && bun test",
    "test:server:coverage": "cd tests/server && bun test --coverage",
    "test:admin-bot": "cd tests/admin-bot && bun test",
    "test:admin-bot:coverage": "cd tests/admin-bot && bun test --coverage",
    "test:admin-bot:e2e": "cd tests/admin-bot-e2e && bun test",
    "test:against-v1": "cd tests/test-against-v1 && bun run test",
    "test:dynamic-scoring": "cd tests/dynamic-scoring && bun run test",
    "rctf": "bun run apps/cli/src/index.ts",
    "prettier": "prettier --write \"**/*.{ts,tsx,svelte,astro,html,json,css,md,mdx}\" --ignore-path .gitignore --ignore-path .prettierignore --log-level warn",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,svelte,astro,html,json,css,md,mdx}\" --ignore-path .gitignore --ignore-path .prettierignore --log-level warn",
    "typecheck": "bun run --filter '*' typecheck",
    "db:generate": "bun run --filter '@rctf/db' generate",
    "db:migrate": "bun run --filter '@rctf/db' migrate",
    "db:pull": "bun run --filter '@rctf/db' pull"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/bun": "1.3.14",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-svelte": "3.5.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "prettier": {
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-svelte",
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss"
    ],
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "overrides": [
      {
        "files": "apps/docs/**/*",
        "options": {
          "printWidth": 100,
          "proseWrap": "never"
        }
      },
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      },
      {
        "files": "*.svelte",
        "options": {
          "printWidth": 100
        }
      }
    ]
  }
}
