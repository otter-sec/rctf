{
  "name": "rctf",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --ellide-lines=0 run --filter '@rctf/api' --filter '@rctf/web' dev",
    "dev:api": "bun run --filter '@rctf/api' dev",
    "dev:web": "bun run --filter '@rctf/web' dev",
    "build": "bun run --filter '*' build",
    "test": "cd tests/server && bun test",
    "test:coverage": "cd tests/server && bun test --coverage",
    "test:integration": "cd tests/test-against-v1 && bun test",
    "prettier": "prettier --write \"**/*.{ts,tsx,svelte,html,json}\" --ignore-path .gitignore",
    "typecheck": "bun run --filter '*' typecheck",
    "db:generate": "bun run --filter '@rctf/db' generate",
    "db:migrate": "bun run --filter '@rctf/db' migrate",
    "db:pull": "bun run --filter '@rctf/db' pull"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/bun": "latest",
    "@types/ioredis-mock": "^8.2.6",
    "ioredis-mock": "^8.13.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-svelte",
      "prettier-plugin-tailwindcss"
    ],
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "overrides": [
      {
        "files": "*.svelte",
        "options": {
          "printWidth": 100
        }
      }
    ]
  }
}
