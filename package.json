{
  "name": "rctf",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --elide-lines=0 --filter '@rctf/api' dev",
    "dev:api": "bun run --elide-lines=0 --filter '@rctf/api' dev",
    "dev:web": "bun run --elide-lines=0 --filter '@rctf/web' dev",
    "build": "bun run --elide-lines=0 --filter '*' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "prettier": "prettier --write . --ignore-path .gitignore",
    "typecheck": "bun run --elide-lines=0 --filter '*' typecheck",
    "db:generate": "bun run --elide-lines=0 --filter '@rctf/db' generate",
    "db:migrate": "bun run --elide-lines=0 --filter '@rctf/db' migrate",
    "db:pull": "bun run --elide-lines=0 --filter '@rctf/db' pull",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/bun": "latest",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "prettier": {
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ],
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "quoteProps": "as-needed",
    "trailingComma": "es5",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "avoid"
  }
}
